
<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Fasssauna.de — Hochwertige Saunen, made in Germany (V3 hell)</title>
<style>
:root{
  --bg:#ffffff;--bg-2:#f7f3ec;--bg-3:#efe8dc;--bg-beratung:#e9efe1;
  --ink:#1C1D2C;--ink-soft:#3b3c49;
  --green:#4f9e45;--green-deep:#246e1b;--green-light:#6fc063;
  --wood:#ae926c;--wood-mid:#997a50;--wood-deep:#8c6a3b;--wood-dark:#745c3a;
  --muted:#6f6a60;--gold:#f8bf00;
  --line:rgba(28,29,44,.10);--line-soft:rgba(28,29,44,.06);
  --on-dark:#F4EFE6;--muted-dark:#b9b1a3;
  --display:"Iowan Old Style","Palatino Linotype",Palatino,Georgia,"Times New Roman",serif;
  --body:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  --mono:ui-monospace,"SF Mono","JetBrains Mono",Menlo,Consolas,monospace;
  --maxw:1240px;--gutter:clamp(20px,5vw,64px);--radius:4px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth;overflow-x:clip}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--body);font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
h1,h2,h3,h4{font-family:var(--display);font-weight:600;line-height:1.1;margin:0;color:var(--ink)}
p{margin:0}
.wrap{max-width:var(--maxw);margin-inline:auto;padding-inline:var(--gutter)}
.section{padding-block:clamp(64px,9vw,120px)}
.eyebrow{font-family:var(--mono);font-size:16px;letter-spacing:.16em;text-transform:uppercase;color:var(--green-deep);margin:0 0 18px;display:flex;align-items:center;gap:12px}
.eyebrow::before{content:"";width:28px;height:1px;background:var(--green);display:inline-block}
.is-tint{background:var(--bg-2)}
.is-dark{background:var(--ink);color:var(--on-dark)}
.is-dark h2,.is-dark h3{color:var(--on-dark)}
.is-dark .eyebrow{color:var(--green-light)}
.is-dark .sec-head p{color:var(--muted-dark)}
.btn{display:inline-flex;align-items:center;gap:10px;font-family:var(--body);font-weight:600;font-size:15px;letter-spacing:.01em;padding:14px 26px;border-radius:var(--radius);cursor:pointer;border:1px solid transparent;transition:transform .18s ease,background .2s ease,color .2s ease,border-color .2s ease}
.btn .arr{transition:transform .2s ease}
.btn:hover .arr{transform:translateX(4px)}
.btn-primary{background:var(--green);color:#08220a}
.btn-primary:hover{background:var(--green-deep);color:#fff}
.btn-ghost{background:transparent;color:var(--ink);border-color:var(--line)}
.btn-ghost:hover{border-color:var(--green);color:var(--green-deep)}
.is-dark .btn-ghost{color:var(--on-dark);border-color:rgba(244,239,230,.28)}
.is-dark .btn-ghost:hover{border-color:var(--green-light);color:var(--green-light)}
.ph{position:relative;overflow:hidden;border-radius:var(--radius);background:linear-gradient(135deg,rgba(174,146,108,.34),rgba(255,255,255,0)),repeating-linear-gradient(90deg,#e6d8c0 0 18px,#ddcdb0 18px 36px);display:flex;align-items:center;justify-content:center}
.ph span{font-family:var(--mono);font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--wood-dark);padding:8px 12px;border:1px dashed var(--wood-mid);border-radius:3px;background:rgba(255,255,255,.6);text-align:center}
.nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
.nav-inner{display:flex;align-items:center;gap:28px;height:88px}
.brand-logo{height:60px;width:auto;display:block}
.nav-links{display:flex;gap:26px;margin-left:auto}
.nav-links a{font-size:14.5px;color:var(--muted);transition:color .2s}
.nav-links a:hover{color:var(--ink)}
.nav .btn{padding:11px 22px}
.nav-toggle{display:none;margin-left:auto;background:none;border:0;color:var(--ink);cursor:pointer}
.primary-nav{display:flex;align-items:center;gap:26px;margin-left:auto}
.nav-list{display:flex;align-items:center;gap:26px;list-style:none;margin:0;padding:0}
.nav-list>li{position:relative}
.nav-list a,.nav-top{font-family:var(--body);font-size:14.5px;color:var(--muted);background:none;border:0;cursor:pointer;padding:0;display:inline-flex;align-items:center;gap:6px;transition:color .2s}
.nav-list a:hover,.nav-top:hover{color:var(--ink)}
.nav-top .chev{width:14px;height:14px;transition:transform .2s}
.nav-cta{padding:10px 20px}
.mega{position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%) translateY(8px);display:grid;grid-template-columns:1fr 1fr;gap:14px 40px;min-width:460px;max-width:calc(100vw - 40px);background:#fff;border:1px solid var(--line);border-radius:8px;box-shadow:0 26px 60px -30px rgba(28,29,44,.4);padding:24px 28px;opacity:0;visibility:hidden;transition:opacity .2s,transform .2s;z-index:70}
.has-mega:hover .mega,.has-mega:focus-within .mega{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0)}
.has-mega:hover .chev,.has-mega:focus-within .chev{transform:rotate(180deg)}
.mega-col{display:flex;flex-direction:column;gap:2px}
.mega-head{font-family:var(--display)!important;font-size:18px!important;font-weight:600;color:var(--ink)!important;padding-bottom:8px!important;margin-bottom:6px;border-bottom:1px solid var(--line)}
.mega-head:hover{color:var(--green-deep)!important}
.mega-col a:not(.mega-head){font-size:15px;color:var(--muted);padding:7px 0!important}
.mega-col a:not(.mega-head):hover{color:var(--green-deep)}
.mega::before{content:"";position:absolute;left:0;right:0;top:-18px;height:18px}
.mega-cta{margin-top:8px!important;padding-top:12px!important;border-top:1px solid var(--line);color:var(--green-deep)!important;font-weight:600}
.hero{padding-block:clamp(36px,5vw,64px) 0;background:var(--bg)}
.hero-wrap{display:flex;flex-direction:column}
/* Bildbox: Inhaltsbreite, abgerundet, kein Overlay */
.hero-media{position:relative;aspect-ratio:16/9;border-radius:var(--radius);overflow:hidden;background:var(--bg-2);box-shadow:0 26px 64px -36px rgba(28,29,44,.45)}
.slides{position:absolute;inset:0}
.slide{position:absolute;inset:0;opacity:0;transition:opacity 1.1s ease}
.slide.active{opacity:1}
.slide img{width:100%;height:100%;object-fit:cover;display:block;transform:scale(1.001);transition:transform 7.5s linear;will-change:transform}
/* Textstreifen darunter */
.hero-panel{padding:clamp(26px,3.4vw,40px) 0 0;max-width:820px;overflow:hidden}
.hero h1{font-size:clamp(32px,4.6vw,56px);font-weight:600;letter-spacing:-.01em;color:var(--ink);text-wrap:balance}
.hero h1 em{font-style:italic;color:var(--green-deep)}
.hero-sub{margin-top:18px;font-size:clamp(16px,1.6vw,19px);color:var(--ink-soft);max-width:62ch}
.hero-cta{margin-top:26px;display:flex;gap:14px;flex-wrap:wrap}
.hero-foot{display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;margin-top:24px;padding-top:20px;border-top:1px solid var(--line)}
.hero-cap{font-family:var(--mono);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--wood-deep);display:flex;align-items:center;gap:10px;min-height:1.1em}
.hero-cap::before{content:"";width:22px;height:1px;background:var(--wood);flex:none;transition:width .4s ease}
.hero-cap.in{animation:slideInLeft .6s cubic-bezier(.2,.7,0,1) both}
.hero-anim{animation:slideInLeft .7s cubic-bezier(.2,.7,0,1) both}
@keyframes slideInLeft{from{opacity:0;transform:translateX(-28px)}to{opacity:1;transform:translateX(0)}}
.hero-dots{display:flex;gap:10px}
.dot{width:9px;height:9px;border-radius:50%;border:1px solid var(--wood-mid);background:transparent;cursor:pointer;padding:0;transition:.2s}
.dot.active{background:var(--green);border-color:var(--green);transform:scale(1.15)}
/* Beratungstermin-Block */
.berater-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px}
.berater{display:flex;align-items:center;gap:18px;background:var(--bg);border:1px solid var(--line);border-radius:var(--radius);padding:20px 24px}
.berater img{width:74px;height:74px;border-radius:50%;object-fit:cover;flex:none;border:2px solid var(--green)}
.berater .r-name{font-family:var(--display);font-size:21px;font-weight:600;color:var(--ink)}
.berater .r-phone{display:inline-flex;align-items:center;gap:9px;margin-top:8px;font-weight:600;font-size:16px;color:var(--green-deep)}
.berater .r-phone:hover{color:var(--green)}
.berater .r-phone svg{flex:none;color:var(--green)}
.berater .r-label{font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-right:4px}
/* Berater-Band (Site-Standard-Komponente) */
.berater-band{background:var(--bg-beratung)}
.berater-band .berater{box-shadow:0 14px 34px -22px rgba(28,29,44,.4)}
.bband{display:grid;grid-template-columns:1fr auto;gap:clamp(24px,4vw,48px);align-items:start}
.bband-cards{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.bband-actions{display:flex;flex-direction:column;gap:12px;min-width:240px}
.bband-actions .btn{justify-content:center}
@media(max-width:980px){.bband{grid-template-columns:1fr}.bband-actions{flex-direction:row;min-width:0}.bband-actions .btn{flex:1}}
@media(max-width:600px){.bband-cards{grid-template-columns:1fr}.bband-actions{flex-direction:column}}
/* Beratungs-Block kompakter + Weißraum zum Slider */
#beratung{padding-block:clamp(30px,4vw,56px);margin-top:clamp(28px,5vw,64px)}
#beratung .sec-head{margin-bottom:clamp(18px,2.4vw,28px)}
.panorama{position:relative;height:clamp(220px,32vw,400px);overflow:hidden;background:var(--bg-3)}
.panorama .ph{position:absolute;inset:-12% 0;border-radius:0;will-change:transform}
.panorama .ph::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 0%,transparent 55%,rgba(255,255,255,.82) 100%)}
.panorama .cap{position:absolute;inset:auto 0 0 0;z-index:2;padding:22px var(--gutter)}
.panorama .cap span{display:none}
.panorama .cap b{display:block;font-family:var(--display);font-size:clamp(18px,2.4vw,26px);font-weight:600;color:var(--ink);margin-top:6px}
.sec-head{margin-bottom:clamp(36px,5vw,60px)}
.sec-head h2{font-size:clamp(30px,4.4vw,50px);letter-spacing:-.01em;text-wrap:balance}
.sec-head p:not(.eyebrow){margin-top:18px;color:var(--muted);font-size:18px;max-width:none}
.family-label{display:flex;align-items:baseline;gap:16px;margin:38px 0 22px;font-family:var(--mono);font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--wood-deep)}
.family-label::after{content:"";flex:1;height:1px;background:var(--line)}
.grid{display:grid;gap:22px;grid-template-columns:repeat(3,1fr)}
.card{background:var(--bg);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;transition:transform .25s ease,box-shadow .25s ease}
.card:hover{transform:translateY(-5px);box-shadow:0 18px 44px -24px rgba(28,29,44,.35)}
.card .ph{aspect-ratio:4/3;border-radius:0}
.card-body{padding:22px 22px 26px;display:flex;flex-direction:column;gap:10px;flex:1}
.card-body h3{font-size:23px}
.card-body .tag{align-self:flex-start;font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#fff;background:var(--wood-deep);padding:4px 9px;border-radius:99px}
.card-body .tag.tag-green{background:var(--green-deep)}
.card-body p{color:var(--muted);font-size:15px;flex:1}
.card-link{font-size:14px;font-weight:600;color:var(--green-deep);display:inline-flex;gap:8px;align-items:center}
.usp-grid{display:grid;gap:22px;grid-template-columns:repeat(2,1fr)}
.usp{background:var(--bg);border:1px solid var(--line);border-radius:var(--radius);padding:clamp(26px,3.2vw,40px)}
.usp .ico{width:44px;height:44px;border:1px solid var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--green-deep);margin-bottom:20px}
.usp h3{font-size:22px;margin-bottom:10px}
.usp p{color:var(--muted);font-size:15.5px}
.steps{display:grid;gap:22px;grid-template-columns:repeat(3,1fr)}
.step{background:var(--bg);border:1px solid var(--line);border-radius:var(--radius);padding:30px;position:relative}
.step .num{font-family:var(--display);font-size:46px;color:var(--green);line-height:1}
.step h3{font-size:21px;margin:14px 0 10px}
.step p{color:var(--muted);font-size:15px}
.strip{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:30px}
.strip .ph{aspect-ratio:1/1}
.split{display:grid;grid-template-columns:1.05fr 1fr;gap:clamp(28px,5vw,64px);align-items:center}
.split .ph{aspect-ratio:5/4;min-height:280px}
.split h2{font-size:clamp(28px,4vw,46px)}
.split p{margin-top:18px;color:var(--muted);font-size:18px}
.split .btn{margin-top:28px}
.ausstellung{display:grid;grid-template-columns:1.2fr .8fr;gap:clamp(28px,5vw,56px);align-items:stretch}
.ausstellung .ph{min-height:340px}
.messe-list{display:flex;flex-direction:column;border-top:1px solid var(--line)}
.messe{display:flex;gap:18px;align-items:baseline;padding:20px 4px;border-bottom:1px solid var(--line)}
.messe .date{font-family:var(--mono);font-size:13px;color:var(--green-deep);min-width:108px}
.messe b{font-family:var(--display);font-weight:600;font-size:19px}
.messe small{display:block;color:var(--muted);font-family:var(--body);font-size:14px;margin-top:2px}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.post .ph{aspect-ratio:16/10;margin-bottom:16px}
.post .meta{font-family:var(--mono);font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--green-deep);margin-bottom:8px}
.post h3{font-size:21px;line-height:1.25}
.post p{color:var(--muted);font-size:15px;margin-top:10px}
.cta-band{text-align:center;background:linear-gradient(180deg,var(--bg-2),#eef3ea)}
.cta-band h2{font-size:clamp(30px,5vw,56px);max-width:18ch;margin-inline:auto;letter-spacing:-.01em}
.cta-band p{margin:20px auto 0;max-width:52ch;color:var(--muted);font-size:18px}
.cta-band .btn{margin-top:32px}
.footer{background:var(--ink);color:var(--on-dark);padding-block:64px 32px}
.foot-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:40px}
.footer .brand-logo{margin-bottom:18px;height:64px}
.footer p.about{color:var(--muted-dark);font-size:15px;max-width:34ch}
.foot-col h4{font-family:var(--body);font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--green-light);margin-bottom:16px;font-weight:600}
.foot-col a{display:block;color:var(--muted-dark);font-size:15px;padding:6px 0;transition:color .2s}
.foot-col a:hover{color:var(--on-dark)}
.foot-bottom{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-top:48px;padding-top:24px;border-top:1px solid rgba(244,239,230,.14);color:var(--muted-dark);font-size:13.5px}
@media(max-width:1024px){.grid,.steps,.blog-grid{grid-template-columns:repeat(2,1fr)}.foot-grid{grid-template-columns:1fr 1fr}}
@media(max-width:760px){body{font-size:16px}.nav-toggle{display:inline-flex}.nav-inner{height:72px}.brand-logo{height:50px}.grid,.steps,.blog-grid,.usp-grid,.split,.ausstellung,.strip,.berater-grid{grid-template-columns:1fr}.strip{grid-template-columns:repeat(2,1fr)}.foot-grid{grid-template-columns:1fr 1fr}
  .primary-nav{position:fixed;inset:72px 0 auto 0;margin:0;flex-direction:column;align-items:stretch;gap:0;background:#fff;border-bottom:1px solid var(--line);box-shadow:0 24px 40px -28px rgba(28,29,44,.4);padding:8px var(--gutter) 20px;max-height:calc(100vh - 72px);overflow:auto;transform:translateY(-12px);opacity:0;visibility:hidden;transition:.22s}
  .nav-open .primary-nav{transform:translateY(0);opacity:1;visibility:visible}
  .nav-list{flex-direction:column;align-items:stretch;gap:0;width:100%}
  .nav-list>li{border-bottom:1px solid var(--line)}
  .nav-list a,.nav-top{padding:15px 2px!important;font-size:16px;width:100%;justify-content:space-between}
  .nav-cta{margin-top:16px;justify-content:center}
  .mega{position:static;transform:none;opacity:1;visibility:visible;display:none;grid-template-columns:1fr;min-width:0;border:0;box-shadow:none;padding:0 0 10px;gap:0}
  .has-mega.open .mega{display:grid}
  .has-mega.open .chev{transform:rotate(180deg)}
  .mega-head{margin-top:6px}
}
@media(max-width:480px){.foot-grid{grid-template-columns:1fr}}
@media(prefers-reduced-motion:reduce){*{scroll-behavior:auto!important}.slide{transition:opacity .01ms}.slide.active img,.hero-cap.in,.hero-anim{animation:none!important}.panorama .ph{transform:none!important}}
</style>
</head>
<body>

<header class="nav">
  <div class="wrap nav-inner">
    <a href="index.html" aria-label="Fasssauna.de Startseite"><img class="brand-logo" src="assets/old-logo2.png" alt="FassSauna Logo"></a>
    <button class="nav-toggle" aria-label="Menü" aria-expanded="false" aria-controls="primary-nav"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h18M3 12h18M3 18h18"/></svg></button>
    <nav class="primary-nav" id="primary-nav">
      <ul class="nav-list">
        <li class="has-mega">
          <button class="nav-top" aria-expanded="false">Saunamodelle <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
          <div class="mega">
            <div class="mega-col">
              <a class="mega-head" href="oval-saunen.html">Oval Saunen</a>
              <a href="oval-sauna-premium.html">Oval Sauna Premium</a>
              <a href="oval-sauna-palkkio.html">Oval Sauna Palkkio</a>
              <a href="oval-sauna-kolmikko.html">Oval Sauna Kolmikko</a>
            </div>
            <div class="mega-col">
              <a class="mega-head" href="fasssaunen.html">Fasssaunen</a>
              <a href="fasssauna-standard.html">FassSauna Standard</a>
              <a href="fasssauna-xl.html">FassSauna XL</a>
              <a href="fasssauna-suuri.html">FassSauna Suuri</a>
              <a class="mega-cta" href="vorraumvarianten.html">Vorraumvarianten &rarr;</a>
            </div>
          </div>
        </li>
        <li><a href="ausstattung.html">Ausstattung &amp; Material</a></li>
        <li><a href="ausstellung-beratung.html">Ausstellung &amp; Beratung</a></li>
        <li><a href="magazin.html">Magazin</a></li>
      </ul>
      <a class="btn btn-primary nav-cta" href="beratungstermin.html">Beratungstermin <span class="arr">→</span></a>
    </nav>
  </div>
</header>

<section class="hero" data-od-id="hero">
  <div class="wrap hero-wrap">
    <!-- Bild oben: Inhaltsbreite, abgerundet, ohne Overlay. Ken-Burns-Zoom auf dem aktiven Slide. -->
    <div class="hero-media">
      <div class="slides">
        <div class="slide active" data-cap="FassSauna XL im Garten"><img src="assets/bilder/startseite/Slider/fasssauna-xl.jpg" alt="FassSauna XL im Garten" style="object-position:center 42%"></div>
        <div class="slide" data-cap="Innenraum aus Thermoholz"><img src="assets/bilder/startseite/Slider/fasssauna-innenraum.jpg" alt="Innenraum einer FassSauna aus Thermoholz" style="object-position:center 35%"></div>
        <div class="slide" data-cap="Oval Sauna Premium mit Terrasse"><img src="assets/bilder/startseite/Slider/oval-sauna-premium-terrasse.jpg" alt="Oval Sauna Premium mit Terrasse und Liegen" style="object-position:center 45%"></div>
        <div class="slide" data-cap="Oval Sauna Premium – getrennter Ruheraum"><img src="assets/bilder/startseite/Slider/oval-sauna-premium-innen.jpeg" alt="Oval Sauna Premium – Innenraum mit getrenntem Ruheraum" style="object-position:center 40%"></div>
        <div class="slide" data-cap="FassSauna XL mit Vorraum"><img src="assets/bilder/startseite/Slider/fasssauna-xl-vorraum-frueehling.jpg" alt="FassSauna XL mit Vorraum im Frühling" style="object-position:center 48%"></div>
      </div>
    </div>
    <!-- Textstreifen darunter -->
    <div class="hero-panel hero-anim">
      <p class="eyebrow">Das Original seit über 20 Jahren · Made in Germany</p>
      <h1>Hochwertige Saunen — <em>von uns gefertigt, von uns aufgebaut.</em></h1>
      <p class="hero-sub">100 % Thermoholz, Isolierverglasung, keine Dachpappe – und wir bauen auf. Ein Showroom für Saunen aus eigener Schreinerei statt anonymem Online-Kauf.</p>
      <div class="hero-foot">
        <div class="hero-dots" id="dots"></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== BERATUNGSTERMIN-BLOCK ===== -->
<section class="section berater-band" id="beratung" data-od-id="beratung">
  <div class="wrap">
    <div class="sec-head">

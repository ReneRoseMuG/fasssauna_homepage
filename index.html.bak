<script>
(function(){
  var slides=[].slice.call(document.querySelectorAll('.slide'));
  var dotsBox=document.getElementById('dots');var cap=document.getElementById('heroCap');var i=0,timer;
  slides.forEach(function(_,n){var b=document.createElement('button');b.className='dot'+(n===0?' active':'');b.setAttribute('aria-label','Bild '+(n+1));b.addEventListener('click',function(){go(n);reset();});dotsBox.appendChild(b);});
  var dots=[].slice.call(dotsBox.children);
  var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function setCap(){if(!cap)return;cap.classList.remove('in');void cap.offsetWidth;cap.textContent=slides[i].getAttribute('data-cap')||'';cap.classList.add('in');}
  function zoom(){if(reduce)return;var img=slides[i].querySelector('img');if(!img)return;img.style.transition='none';img.style.transform='scale(1.001)';void img.offsetWidth;img.style.transition='transform 7.5s linear';img.style.transform='scale(1.09)';}
  function go(n){slides[i].classList.remove('active');dots[i].classList.remove('active');i=(n+slides.length)%slides.length;slides[i].classList.add('active');dots[i].classList.add('active');setCap();zoom();}
  function reset(){clearInterval(timer);timer=setInterval(function(){go(i+1);},6000);}
  setCap();zoom();reset();
})();
(function(){
  var mqD=window.matchMedia('(min-width:761px)'),mqM=window.matchMedia('(prefers-reduced-motion: no-preference)');
  if(!mqD.matches||!mqM.matches)return;
  var strips=[].slice.call(document.querySelectorAll('[data-parallax] .ph')),ticking=false;
  function update(){strips.forEach(function(el){var r=el.parentElement.getBoundingClientRect(),vh=window.innerHeight;if(r.bottom<0||r.top>vh)return;var prog=(r.top+r.height/2-vh/2)/vh;el.style.transform='translateY('+(prog*-26)+'px)';});ticking=false;}
  window.addEventListener('scroll',function(){if(!ticking){requestAnimationFrame(update);ticking=true;}},{passive:true});update();
})();
</script>
<script src="js/site.js"></script>
